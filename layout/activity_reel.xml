<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Activity.ReelActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/reelToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:title="Post Your Reel"
        app:titleTextColor="@color/text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btnReels"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="100dp"
        android:layout_height="40dp"
        android:elevation="12dp"
        android:layout_marginTop="10dp"
        android:text="Post"
        android:textStyle="bold"
        android:textColor="@color/text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.95"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/reelToolbar" />

    <VideoView
        android:id="@+id/video"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginStart="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnReels" />

    <EditText
        android:id="@+id/reelCaption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="15dp"
        android:hint="Write here something !!"
        android:textColor="@color/text"
        android:background="@drawable/btn_profile"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@+id/video" />


    <Button
        android:id="@+id/gallery"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="120dp"
        android:layout_height="40dp"
        android:elevation="12dp"
        android:layout_marginTop="10dp"
        android:text="Gallery"
        android:textColor="@color/text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/reelCaption" />
</androidx.constraintlayout.widget.ConstraintLayout>