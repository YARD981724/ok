<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Activity.ChatUserActivity">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardSearch"
        android:layout_width="match_parent"
        app:cardCornerRadius="40dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        app:cardElevation="50dp"
        android:layout_marginTop="5dp"
        android:layout_height="50dp">

        <ImageView
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_marginTop="8dp"
            android:layout_marginStart="15dp"
            android:src="@drawable/search"/>

        <EditText
            android:id="@+id/search"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:hint="Search your best friends..."
            android:layout_gravity="center"
            android:textColorHint="@color/text"
            android:textColorHighlight="@color/text"
            android:background="@color/transparent"
            android:paddingStart="60dp" />


    </androidx.cardview.widget.CardView>



    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/chat_shimmer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/data_view"
            android:orientation="vertical">
           <include layout="@layout/chat_user_shimmer"/>
            <include layout="@layout/chat_user_shimmer"/>
            <include layout="@layout/chat_user_shimmer"/>
            <include layout="@layout/chat_user_shimmer"/>
            <include layout="@layout/chat_user_shimmer"/>
            <include layout="@layout/chat_user_shimmer"/>
            <include layout="@layout/chat_user_shimmer"/>
            <include layout="@layout/chat_user_shimmer"/>
            <include layout="@layout/chat_user_shimmer"/>
            <include layout="@layout/chat_user_shimmer"/>
            <include layout="@layout/chat_user_shimmer"/>
            <include layout="@layout/chat_user_shimmer"/>
            <include layout="@layout/chat_user_shimmer"/>



        </LinearLayout>
    </com.facebook.shimmer.ShimmerFrameLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chat_rv_user"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/cardSearch"/>

</RelativeLayout>