<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".Activity.ProfileDetail">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/profileToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:titleTextColor="@color/white"
        app:title="Profile Detail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />



    <TextView
        android:id="@+id/user_detail_full_Name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:paddingStart="10dp"
        app:layout_constraintEnd_toEndOf="@id/profileToolbar"
        app:layout_constraintStart_toStartOf="@id/profileToolbar"
        app:layout_constraintTop_toBottomOf="@+id/profileToolbar" />

    <TextView
        android:id="@+id/user_detail_Name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:paddingStart="10dp"
        app:layout_constraintEnd_toEndOf="@id/user_detail_full_Name"
        app:layout_constraintStart_toStartOf="@id/user_detail_full_Name"
        app:layout_constraintTop_toBottomOf="@+id/user_detail_full_Name" />

    <ImageView
        android:id="@+id/post_detail_image"
        android:layout_width="match_parent"
        android:layout_height="500dp"
        android:layout_marginTop="50dp"
        android:layout_marginStart="5dp"
        android:layout_marginEnd="5dp"
        app:layout_constraintTop_toBottomOf="@id/user_detail_Name"
        app:layout_constraintEnd_toEndOf="@id/user_detail_Name"
        app:layout_constraintStart_toStartOf="@id/user_detail_Name"

        >

    </ImageView>


</androidx.constraintlayout.widget.ConstraintLayout>